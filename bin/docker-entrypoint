#!/bin/bash -e

if [ "${WAIT_FOR_DEPENDENCIES:-false}" = "true" ]; then
  /rails/bin/wait-for-services
fi

# Optionally prepare database on boot (enabled by docker-compose for API service).
if [ "${RUN_DB_PREPARE:-false}" = "true" ]; then
  echo "Preparing database..."
  ./bin/rails db:prepare
fi

# Remove stale Rails server PID from previous runs (common with bind-mounted tmp/).
rm -f /rails/tmp/pids/server.pid

exec "${@}"
