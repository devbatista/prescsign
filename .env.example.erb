# -----------------------------------------------------------------------------
# PrescSign API - Environment Template
# Copy to `.env` in local development and adjust values.
# -----------------------------------------------------------------------------

# Core
RAILS_ENV=development
RAILS_LOG_LEVEL=debug
RAILS_MAX_THREADS=5
RAILS_SERVE_STATIC_FILES=

# App URL (used by mailer default_url_options)
APP_HOST=api.prescsign.local
APP_PORT=3000
APP_PROTOCOL=http
API_PORT_HOST=3000
NGINX_PORT_HOST=8080
POSTGRES_PORT_HOST=5432
REDIS_PORT_HOST=6379
WAIT_FOR_DEPENDENCIES=true
WAIT_FOR_SERVICES_TIMEOUT=60
WAIT_FOR_SERVICES_SLEEP=2

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB_DEVELOPMENT=prescsign_development
POSTGRES_DB_TEST=prescsign_test
POSTGRES_DB_PRODUCTION=prescsign_production

# In production prefer DATABASE_URL
# Example: postgres://user:password@db:5432/prescsign_production
# DATABASE_URL=

# Redis / Sidekiq / ActionCable
REDIS_URL=redis://localhost:6379/1

# Queue / Jobs
# development: async (default)
# production: sidekiq (recommended)
ACTIVE_JOB_QUEUE_ADAPTER=async
REDIS_URL=redis://localhost:6379/1
SIDEKIQ_CONCURRENCY=5

# Storage
# development/test usually local/test
# production usually s3 (AWS S3 or R2 via endpoint)
ACTIVE_STORAGE_SERVICE=local
DOCUMENTS_PDF_SIGNED_URL_EXPIRES_IN=900

# Retention policy (days)
# Tune these values based on legal/compliance requirements in your deployment.
RETENTION_DOCUMENT_VERSIONS_DAYS=1825
RETENTION_AUDIT_LOGS_DAYS=2190
RETENTION_DELIVERY_LOGS_DAYS=365
RETENTION_TMP_FILES_DAYS=7
RETENTION_UNATTACHED_BLOBS_DAYS=2

# Mailer behavior
RAISE_MAIL_DELIVERY_ERRORS=false

# CORS
# Comma-separated allowlist. Required in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Integration placeholders (planned in MVP scope)
# -----------------------------------------------------------------------------

# JWT / Authentication
# Required in production.
JWT_SECRET_KEY=change-me-in-production

# Object storage (S3 / R2)
# If S3_BUCKET is set, related S3_* credentials should also be set.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
# Some S3-compatible providers may require path-style URLs.
S3_FORCE_PATH_STYLE=false

# SendGrid
# SENDGRID_FROM_EMAIL becomes required when SENDGRID_API_KEY is configured.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio
# TWILIO_AUTH_TOKEN and TWILIO_FROM_NUMBER become required when TWILIO_ACCOUNT_SID is configured.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp Cloud API
# WHATSAPP_PHONE_NUMBER_ID becomes required when WHATSAPP_ACCESS_TOKEN is configured.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
