<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #eef3f7;
        color: #152033;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      }

      .wrapper {
        width: 100%;
        padding: 30px 12px;
        background:
          radial-gradient(circle at 8% 8%, #dbeafe 0%, transparent 40%),
          radial-gradient(circle at 92% 0%, #ccfbf1 0%, transparent 42%),
          #eef3f7;
      }

      .card {
        max-width: 560px;
        margin: 0 auto;
        border: 1px solid #d8e1ec;
        border-radius: 16px;
        background-color: #ffffff;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
        overflow: hidden;
      }

      .header {
        padding: 28px 24px 20px;
        background: linear-gradient(120deg, #0f766e 0%, #0b8f8b 55%, #0ea5a5 100%);
        color: #ffffff;
      }

      .header h1 {
        margin: 0;
        font-size: 22px;
        line-height: 1.2;
        letter-spacing: 0.2px;
      }

      .header p {
        margin: 8px 0 0;
        color: rgba(255, 255, 255, 0.9);
        font-size: 13px;
      }

      .content {
        padding: 28px 24px 20px;
        font-size: 15px;
        line-height: 1.75;
      }

      .content p {
        margin: 0 0 16px;
      }

      .content p:last-child {
        margin-bottom: 0;
      }

      .button {
        display: inline-block;
        background: linear-gradient(120deg, #0f766e 0%, #0ea5a5 100%);
        color: #ffffff !important;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        padding: 12px 20px;
        border-radius: 10px;
        box-shadow: 0 10px 18px rgba(15, 118, 110, 0.28);
      }

      .link-box {
        margin-top: 14px;
        padding: 12px;
        border: 1px solid #d8e1ec;
        border-radius: 10px;
        background-color: #f8fafc;
        color: #334155;
        font-size: 12px;
        line-height: 1.6;
        word-break: break-all;
      }

      .muted {
        color: #64748b;
      }

      .divider {
        height: 1px;
        background: linear-gradient(to right, transparent, #d9e3ef, transparent);
        margin: 0 24px 18px;
      }

      .footer {
        padding: 0 24px 24px;
        color: #6b7280;
        font-size: 12px;
        line-height: 1.6;
      }

      @media (max-width: 600px) {
        .wrapper {
          padding: 16px 8px;
        }

        .header,
        .content {
          padding-left: 16px;
          padding-right: 16px;
        }

        .footer,
        .divider {
          padding-left: 16px;
          padding-right: 16px;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="card">
        <div class="header">
          <h1>PrescSign</h1>
          <p>Confirmação de cadastro</p>
        </div>
        <div class="content">
          <%= yield %>
        </div>
        <div class="divider"></div>
        <div class="footer">
          <p>Se você não reconhece este e-mail, pode ignorá-lo com segurança.</p>
          <p>© <%= Time.current.year %> PrescSign</p>
        </div>
      </div>
    </div>
  </body>
</html>
